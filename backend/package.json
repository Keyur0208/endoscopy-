{
  "name": "endoscopy-backend",
  "version": "1.0.0",
  "private": true,
  "main": "build/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node build/app.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "seed:admin": "ts-node --transpile-only src/database/seeds/admin.ts",
    "seed:configuration:orgs": "ts-node --transpile-only src/database/seeds/configuration-org-sync.ts",
    "seed:patient:sync": "ts-node --transpile-only src/database/seeds/patient-sync.ts",
    "prisma:generate": "prisma generate --schema=./src/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./src/prisma/schema.prisma",
    "prisma:format": "prisma format --schema=./src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./src/prisma/schema.prisma"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "celebrate": "^15.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "endoscopy-shared": "file:../endoscopy-shared",
    "eslint": "^10.3.0",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "morgan": "^1.10.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prisma/client": "^6.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "globals": "^17.6.0",
    "nodemon": "^3.1.4",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.59.2"
  }
}